# OpenAI-compatible judge endpoint.
# Examples:
#   JUDGE_API_URL=https://api.openai.com
#   JUDGE_API_URL=http://127.0.0.1:8000
JUDGE_API_URL=https://api.example.com

# Leave empty for local vLLM if it does not require auth.
JUDGE_API_KEY=

# Any strong instruction/code model exposed by the endpoint.
JUDGE_MODEL=your-judge-model
